            "\u0412\u0441\u0435\u0433\u0434\u0430 \u043f\u0440\u043e\u0432\u0435\u0440\u044f\u0439\u0442\u0435, \u043c\u043e\u0436\u043d\u043e \u043b\u0438 \u0432\u044b\u043f\u043e\u043b\u043d\u0438\u0442\u044c \u0432\u044b\u0447\u0438\u0442\u0430\u043d\u0438\u0435 \u0432 \u043d\u0430\u0442\u0443\u0440\u0430\u043b\u044c\u043d\u044b\u0445 \u0447\u0438\u0441\u043b\u0430\u0445 (\u0443\u043c\u0435\u043d\u044c\u0448\u0430\u0435\u043c\u043e\u0435 \u0434\u043e\u043b\u0436\u043d\u043e \u0431\u044b\u0442\u044c \u0431\u043e\u043b\u044c\u0448\u0435 \u0432\u044b\u0447\u0438\u0442\u0430\u0435\u043c\u043e\u0433\u043e)",
            "\u041f\u0440\u0438 \u0440\u0435\u0448\u0435\u043d\u0438\u0438 \u0441\u043b\u043e\u0436\u043d\u044b\u0445 \u0432\u044b\u0440\u0430\u0436\u0435\u043d\u0438\u0439 \u043e\u0431\u044f\u0437\u0430\u0442\u0435\u043b\u044c\u043d\u043e \u043e\u0442\u043c\u0435\u0447\u0430\u0439\u0442\u0435 \u043f\u043e\u0440\u044f\u0434\u043e\u043a \u0434\u0435\u0439\u0441\u0442\u0432\u0438\u0439 \u0446\u0438\u0444\u0440\u0430\u043c\u0438 \u043d\u0430\u0434 \u0437\u043d\u0430\u043a\u0430\u043c\u0438",
            "\u0414\u043b\u044f \u043f\u0440\u043e\u0432\u0435\u0440\u043a\u0438 \u0434\u0435\u043b\u0435\u043d\u0438\u044f \u0443\u043c\u043d\u043e\u0436\u044c\u0442\u0435 \u0447\u0430\u0441\u0442\u043d\u043e\u0435 \u043d\u0430 \u0434\u0435\u043b\u0438\u0442\u0435\u043b\u044c \u0438 \u043f\u0440\u0438\u0431\u0430\u0432\u044c\u0442\u0435 \u043e\u0441\u0442\u0430\u0442\u043e\u043a \u2014 \u0434\u043e\u043b\u0436\u043d\u043e \u043f\u043e\u043b\u0443\u0447\u0438\u0442\u044c\u0441\u044f \u0434\u0435\u043b\u0438\u043c\u043e\u0435",
            "\u0417\u0430\u043f\u043e\u043c\u0438\u043d\u0430\u0439\u0442\u0435 \u043a\u0432\u0430\u0434\u0440\u0430\u0442\u044b \u0447\u0438\u0441\u0435\u043b \u0434\u043e 20 \u2014 \u044d\u0442\u043e \u0441\u0438\u043b\u044c\u043d\u043e \u0443\u0441\u043a\u043e\u0440\u0438\u0442 \u0432\u044b\u0447\u0438\u0441\u043b\u0435\u043d\u0438\u044f",
            "\u0412 \u0442\u0435\u043a\u0441\u0442\u043e\u0432\u044b\u0445 \u0437\u0430\u0434\u0430\u0447\u0430\u0445 \u0441\u043d\u0430\u0447\u0430\u043b\u0430 \u043e\u043f\u0440\u0435\u0434\u0435\u043b\u044f\u0439\u0442\u0435, \u043a\u0430\u043a\u043e\u0435 \u0434\u0435\u0439\u0441\u0442\u0432\u0438\u0435 \u043d\u0443\u0436\u043d\u043e: \u0435\u0441\u043b\u0438 \u043e\u0431\u044a\u0435\u0434\u0438\u043d\u044f\u0435\u043c \u2014 \u0441\u043a\u043b\u0430\u0434\u044b\u0432\u0430\u0435\u043c, \u0435\u0441\u043b\u0438 \u043d\u0430\u0445\u043e\u0434\u0438\u043c \u0440\u0430\u0437\u043d\u0438\u0446\u0443 \u2014 \u0432\u044b\u0447\u0438\u0442\u0430\u0435\u043c, \u0435\u0441\u043b\u0438 \u043d\u0435\u0441\u043a\u043e\u043b\u044c\u043a\u043e \u043e\u0434\u0438\u043d\u0430\u043a\u043e\u0432\u044b\u0445 \u0433\u0440\u0443\u043f\u043f \u2014 \u0443\u043c\u043d\u043e\u0436\u0430\u0435\u043c, \u0435\u0441\u043b\u0438 \u0434\u0435\u043b\u0438\u043c \u043d\u0430 \u0447\u0430\u0441\u0442\u0438 \u2014 \u0434\u0435\u043b\u0438\u043c",
            "\u041f\u0440\u0438 \u0440\u0430\u0431\u043e\u0442\u0435 \u0441 \u0431\u043e\u043b\u044c\u0448\u0438\u043c\u0438 \u0447\u0438\u0441\u043b\u0430\u043c\u0438 \u0438\u0441\u043f\u043e\u043b\u044c\u0437\u0443\u0439\u0442\u0435 \u043f\u0440\u0438\u043a\u0438\u0434\u043a\u0443: \u043e\u043a\u0440\u0443\u0433\u043b\u044f\u0439\u0442\u0435 \u0447\u0438\u0441\u043b\u0430 \u0438 \u043e\u0446\u0435\u043d\u0438\u0432\u0430\u0439\u0442\u0435 \u043f\u0440\u0438\u043c\u0435\u0440\u043d\u044b\u0439 \u0440\u0435\u0437\u0443\u043b\u044c\u0442\u0430\u0442",
            "\u0412\u0441\u0435\u0433\u0434\u0430 \u0437\u0430\u043f\u0438\u0441\u044b\u0432\u0430\u0439\u0442\u0435 \u0440\u0435\u0448\u0435\u043d\u0438\u0435 \u043f\u043e \u0434\u0435\u0439\u0441\u0442\u0432\u0438\u044f\u043c, \u0430 \u043d\u0435 \u043e\u0434\u043d\u0438\u043c \u0432\u044b\u0440\u0430\u0436\u0435\u043d\u0438\u0435\u043c \u2014 \u0442\u0430\u043a \u043b\u0435\u0433\u0447\u0435 \u043d\u0430\u0439\u0442\u0438 \u043e\u0448\u0438\u0431\u043a\u0443"
        ],
